{
  "entities": {
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat session containing messages.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat conversation.",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["user", "ai"],
          "description": "The role of the message sender."
        },
        "content": {
          "type": "string",
          "description": "The text content of the message."
        },
        "agentName": {
          "type": "string",
          "description": "The name of the agent that sent the message (if AI)."
        },
        "agentTier": {
          "type": "string",
          "description": "The tier of the agent."
        },
        "images": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Base64 encoded images attached to the message."
        },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "Artifact" },
          "description": "Artifacts generated in this message."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the message was created."
        }
      },
      "required": ["role", "content", "createdAt"]
    },
    "Artifact": {
      "title": "Artifact",
      "description": "A generated marketing asset.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "content": { "type": "string" },
        "agentName": { "type": "string" },
        "metadata": { "type": "object" }
      }
    },
    "BrainMemory": {
      "title": "BrainMemory",
      "description": "A learned insight or memory stored in the agent's brain.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "roi": { "type": "number" },
        "embedding": { "type": "array", "items": { "type": "number" } }
      },
      "required": ["agentId", "title", "content", "createdAt"]
    },
    "BrandProfile": {
      "title": "BrandProfile",
      "description": "Strategic profile of the user's brand.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "audience": { "type": "string" },
        "tone": { "type": "string" },
        "messaging": { "type": "string" },
        "productDetails": { "type": "string" },
        "competitors": { "type": "string" },
        "dataSources": { "type": "string" }
      }
    },
    "User": {
      "title": "User",
      "description": "User profile and settings.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "A task in the user's management system.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "reminderAt": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "assignedTo": { "type": "string", "description": "The user ID or name the task is assigned to." },
        "image": { "type": "string", "description": "Base64 encoded image attachment." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "priority", "createdAt"]
    },
    "Routine": {
      "title": "Routine",
      "description": "A recurring routine or habit.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly"] },
        "time": { "type": "string" },
        "days": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "frequency", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "An in-app notification for the user.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "success", "error", "task"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["title", "message", "type", "read", "createdAt"]
    },
    "CustomAgent": {
      "title": "CustomAgent",
      "description": "A custom AI agent created by the user.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "tier": { "type": "string" },
        "persona": { "type": "string" },
        "description": { "type": "string" },
        "prompt": { "type": "string" },
        "model": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "tier", "persona", "description", "prompt", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "ChatSession",
      "description": "A chat session."
    },
    "/users/{userId}/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat session."
    },
    "/users/{userId}/brainMemories/{memoryId}": {
      "schema": "BrainMemory",
      "description": "Memories stored for the user's agents."
    },
    "/users/{userId}/brandProfiles/{profileId}": {
      "schema": "BrandProfile",
      "description": "The brand profiles for the user."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "User's tasks."
    },
    "/users/{userId}/routines/{routineId}": {
      "schema": "Routine",
      "description": "User's routines."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User's in-app notifications."
    },
    "/users/{userId}/customAgents/{agentId}": {
      "schema": "CustomAgent",
      "description": "User's custom AI agents."
    }
  }
}
